@model UHabitacional_Web.Models.Edificio

<form class="modal-dialog modal-dialog-centered modal-lg" asp-action="Create">
    <div class="modal-content">
        <div class="modal-header">
            <h1 class="modal-title fs-5">Crear edificio</h1>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
            <div class="row justify-content-center">
                <div class="mb-3 col-3">
                    <label asp-for="Id" class="form-label">Número de edificio</label>
                    <input asp-for="Id" type="text" class="form-control" placeholder="1-2">
                </div>
                <div class="mb-3 col-9">
                    <label asp-for="Calle" class="form-label">Calle</label>
                    <input asp-for="Calle" type="text" class="form-control" placeholder="Boulevard Adolfo Lopez Mateos">
                </div>
                <div class="mb-3 col-2">
                    <label asp-for="NumeroPisos" class="form-label">Pisos</label>
                    <input asp-for="NumeroPisos" type="number" class="form-control" placeholder="9">
                </div>
                <div class="mb-3 col-2">
                    <label asp-for="TotalDeptos" class="form-label">Departamentos</label>
                    <input asp-for="TotalDeptos" type="number" class="form-control" placeholder="36">
                </div>
                <div class="mb-3 col-8">
                    <label asp-for="Estatus" class="form-label">Estatus:</label>
                    <select asp-for="Estatus" class="form-control" asp-items="Html.GetEnumSelectList<EstatusEdificio>()">
                        <option value="" disabled selected>Selecciona estatus</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary w-25" data-bs-dismiss="modal">Cerrar</button>
            <button type="submit" class="btn btn-primary w-25">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-floppy me-1" viewBox="0 0 16 16">
                    <path d="M11 2H9v3h2z" />
                    <path d="M1.5 0h11.586a1.5 1.5 0 0 1 1.06.44l1.415 1.414A1.5 1.5 0 0 1 16 2.914V14.5a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 14.5v-13A1.5 1.5 0 0 1 1.5 0M1 1.5v13a.5.5 0 0 0 .5.5H2v-4.5A1.5 1.5 0 0 1 3.5 9h9a1.5 1.5 0 0 1 1.5 1.5V15h.5a.5.5 0 0 0 .5-.5V2.914a.5.5 0 0 0-.146-.353l-1.415-1.415A.5.5 0 0 0 13.086 1H13v4.5A1.5 1.5 0 0 1 11.5 7h-7A1.5 1.5 0 0 1 3 5.5V1H1.5a.5.5 0 0 0-.5.5m3 4a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 .5-.5V1H4zM3 15h10v-4.5a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5z" />
                </svg>
                Guardar
            </button>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
