@model UHabitacional_Web.Models.Inquilino

<div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
        <div class="modal-header">
            <h1 class="modal-title fs-5">@Model.UsuarioId - Detalles</h1>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
            <div class="row justify-content-center">
                <div class="col-10 py-3 border border-danger bg-danger-subtle text-danger-emphasis rounded mb-4">
                    <p class="fs-6 fw-bold mb-0">¿Está seguro qué desea DESHABILITAR este usuario?</p>
                </div>
                <div class="col-3 fw-medium py-2">Nombre</div>
                <div class="col-7 py-2">@Model.Usuario.Nombre @Model.Usuario.ApellidoPaterno @Model.Usuario.ApellidoMaterno</div>

                <div class="col-3 fw-medium py-2">Correo</div>
                <div class="col-7 py-2">@Model.Usuario.Correo</div>

                <div class="col-3 fw-medium py-2">Estatus</div>
                <div class="col-7 py-2">
                    @if (Model.Usuario.Estatus == EstatusUsuario.Activo)
                    {
                        <h5 class="mb-0"><span class="badge text-bg-success">Activo</span></h5>
                    }
                    else if (Model.Usuario.Estatus == EstatusUsuario.Inactivo)
                    {
                        <h5 class="mb-0"><span class="badge text-bg-secondary">Inactivo</span></h5>
                    }
                    else
                    {
                        <h5 class="mb-0"><span class="badge text-bg-warning">Bloqueado</span></h5>
                    }
                </div>

                <div class="col-3 fw-medium py-2">Rol</div>
                <div class="col-7 py-2">@Model.Usuario.TipoUsuario.Descripcion</div>

                <div class="col-3 fw-medium py-2">Edificio</div>
                <div class="col-7 py-2">@Model.Departamento.EdificioId</div>

                <div class="col-3 fw-medium py-2">Departamento</div>
                <div class="col-7 py-2">@Model.Departamento.NumeroInt</div>

                <div class="col-3 fw-medium py-2">Fecha de inicio</div>
                <div class="col-7 py-2">@Model.FechaInicio.ToString("dd/MM/yyyy")</div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary w-25" data-bs-dismiss="modal">Cerrar</button>
            <form class="w-25" asp-controller="Inquilino" asp-action="Delete" asp-route-id="@Model.UsuarioId" method="post">
                <button type="submit" class="btn btn-danger w-100">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3" viewBox="0 0 16 16">
                        <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5" />
                    </svg>
                    Confirmar
                </button>
            </form>
        </div>
    </div>
</div>
